{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "model": "github-copilot/claude-sonnet-4.6",
  "share": "disabled",
  "disabled_providers": [
    "openai",
    "anthropic",
    "gemini",
    "amazon-bedrock"
  ],
  "permission": {
    "github*": "deny",
    "grafana*": "deny",
    "atlassian*": "deny"
  },
  "provider": {
    "exxeta": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Exxeta",
      "options": {
        "baseURL": "https://ai.exxeta.info/v1",
        "includeUsage": true
      },
      "models": {
        "claude-sonnet-4.6": {
          "name": "Exxeta Claude Sonnet 4.6",
          "cost": {
            "input": 3.3,
            "output": 16.5
          },
          "limit": {
            "context": 200000,
            "output": 64000
          }
        },
        "claude-opus-4.6": {
          "name": "Exxeta Claude Opus 4.6",
          "cost": {
            "input": 5.5,
            "output": 27.5
          },
          "limit": {
            "context": 1000000,
            "output": 128000
          }
        },
        "gpt-5-mini": {
          "name": "Exxeta GPT-5 Mini",
          "cost": {
            "input": 0.15,
            "output": 0.6
          },
          "limit": {
            "context": 128000,
            "output": 4096
          }
        },
        "gpt-5.4": {
          "name": "Exxeta GPT-5.4 Pro",
          "cost": {
            "input": 5,
            "output": 15
          },
          "limit": {
            "context": 200000,
            "output": 64000
          }
        }
      }
    },
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (Local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "gemma4:local-64k": {
          "name": "Gemma4 64k"
        },
        "gemma4:12b-mlx-64k": {
          "name": "Gemma4 64k (MLX)"
        }
      }
    }
  }
}
