{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "model": "github-copilot/claude-sonnet-4.6",
  "share": "disabled",
  "disabled_providers": ["openai", "anthropic", "gemini", "amazon-bedrock"],
  "permission": {
    "github_*": "deny",
    "grafana_*": "deny",
    "atlassian_*": "deny"
  },
  "provider": {
    "exxeta": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Exxeta",
      "options": {
        "baseURL": "{env:OPENAI_API_BASE}",
        "apiKey": "{env:OPENAI_API_KEY}",
        "includeUsage": true
      },
      "models": {
        "eu.anthropic.claude-sonnet-4-6": {
          "name": "Exxeta Claude Sonnet 4.6",
          "cost": {
            "input": 3.3,
            "output": 16.5
          },
          "limit": {
            "context": 200000,
            "output": 64000
          }
        },
        "eu.anthropic.claude-opus-4-6-v1": {
          "name": "Exxeta Claude Opus 4.6",
          "cost": {
            "input": 5.5,
            "output": 27.5
          },
          "limit": {
            "context": 1000000,
            "output": 128000
          }
        }
      }
    }
  }
}
